{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "create-block/hug-media-gallery-query-loop",
  "version": "2.1.0",
  "title": "Hug Media Gallery Query Loop",
  "category": "widgets",
  "icon": "smiley",
  "description": "Example block scaffolded with Create Block tool. Requires Media Library Categories plugin.",
  "example": {},
  "supports": {
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "align": true,
    "alignWide": true
  },
  "textdomain": "hug-media-gallery-query-loop",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "attributes": {
    "mediaTaxonomy": {
      "type": "string",
      "default": ""
    },
    "sortOption": {
      "type": "string",
      "default": "date"
    },
	"order": {
		"type": "string",
		"default": "DESC"
	},
    "imageSize": {
      "type": "string",
      "default": "full"
    },
    "perPage": {
      "type": "number",
      "default": 12
    },
    "columns": {
      "type": "number",
      "default": 3
    },
    "useLightbox": {
      "type": "boolean",
      "default": true
    },
    "layoutStyle": {
      "type": "string",
      "default": "grid"
    },
    "showTitles": {
      "type": "boolean",
      "default": false
    }
  }
}
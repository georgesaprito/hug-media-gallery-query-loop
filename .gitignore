# --- Dependencies ---
# Never track node_modules; it's massive and generated via npm install
node_modules/

# --- Build Logs & Debugging ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# --- OS Specific Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editor/IDE Specific ---
.vscode/
.idea/
*.swp
*.swo

# --- WordPress/Build Tools ---
# We are NOT ignoring /build/ because we want to track the compiled assets.
# However, we can ignore the local-only zip files if you use 'wp-scripts bundle'
/*.zip
